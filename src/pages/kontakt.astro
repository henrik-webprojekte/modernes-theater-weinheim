---
import Layout from "../layouts/Layout.astro"
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"

const preise = [
  {label: "Erwachsene", wert: "11 €"},
  {label: "Ermäßigt", wert: "9 €"},
  {label: "Kinder ≤ 11", wert: "6 €"},
  {label: "Kinotag Di · Starttag Do", wert: "7 €", highlight: true},
]

const zuschlaege = [
  "VIP-Loge +1,50 €",
  "3D +3,00 €",
  "Sneak-Preview 5 €",
  "Kaffee-Tee-Kino 8 €",
  "Überlänge gestaffelt 0,50 – 1,50 €",
]
---

<Layout title="Kontakt — Modernes Theater Weinheim">
  <Header />

  <main>

    <section class="bg-tiefschwarz text-creme relative" style="background: #1A1310;">
      <div class="absolute top-0 left-0 right-0 h-[3px]" style="background: repeating-linear-gradient(90deg, #C9A55C 0 6px, transparent 6px 12px); opacity: 0.5;"></div>
      <div class="max-w-4xl mx-auto px-6 py-20 text-center">
        <p class="text-xs uppercase tracking-[0.3em] text-vintage-gold mb-3">
          Erreichbar & vor Ort
        </p>
        <h1 class="font-display text-4xl md:text-6xl leading-tight text-creme mb-4">
          Kontakt
        </h1>
        <p class="text-base text-creme/80 max-w-2xl mx-auto leading-relaxed">
          Kartenreservierung, Anfragen zur Vermietung, allgemeine Auskünfte — hier finden Sie uns.
        </p>
      </div>
    </section>

    <section class="bg-creme px-6 py-12" style="background: #F5EDE0;">
      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">

        <div>
          <div class="flex items-center gap-2 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6B1818" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <h2 class="font-display text-lg text-tiefschwarz">Anrufen & reservieren</h2>
          </div>
          <p class="text-sm text-tiefschwarz/85 leading-relaxed mb-2">
            Kartenreservierung telefonisch oder direkt an der Kinokasse.
          </p>
          <p class="text-sm text-tiefschwarz/85 leading-relaxed">
            Tel. <a href="tel:0620162155" class="text-kino-rot font-medium">06201 · 62155</a><br />
            Mail <a href="mailto:zentrale@kinoweinheim.de" class="text-kino-rot font-medium">zentrale@kinoweinheim.de</a>
          </p>
        </div>

        <div>
          <div class="flex items-center gap-2 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6B1818" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <h2 class="font-display text-lg text-tiefschwarz">Adresse</h2>
          </div>
          <p class="text-sm text-tiefschwarz/85 leading-relaxed">
            Modernes Theater<br />
            Hauptstraße 61<br />
            69469 Weinheim
          </p>
        </div>

      </div>
    </section>

    <section id="anfahrt" class="bg-off-white px-6 py-12" style="background: #FAF6EE;">
      <div class="max-w-4xl mx-auto">
        <p class="text-xs uppercase tracking-[0.2em] text-warmes-braun mb-3">Anfahrt</p>
        <h2 class="font-display text-2xl text-tiefschwarz mb-6">So finden Sie uns</h2>

        <div class="aspect-[16/8] rounded border overflow-hidden relative" style="border-color: #C9A55C; background: #E5D8C0;">
          <div class="absolute inset-0" style="background: repeating-linear-gradient(45deg, #E5D8C0 0 12px, #DACDB4 12px 24px); opacity: 0.5;"></div>
          <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#6B1818" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <p class="text-xs uppercase tracking-widest text-warmes-braun mt-2">Karte — Einbindung folgt</p>
            <a
              href="https://www.openstreetmap.org/?mlat=49.5495&mlon=8.6698#map=18/49.5495/8.6698"
              target="_blank"
              rel="noopener"
              class="text-xs text-kino-rot mt-1 underline"
            >Auf OpenStreetMap ansehen ↗</a>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6 text-sm text-tiefschwarz/85 leading-relaxed">
          <div>
            <p class="text-xs uppercase tracking-widest text-warmes-braun mb-1">Mit dem Auto</p>
            <p>Innerhalb der Fußgängerzone — Parkplätze in umliegenden Parkhäusern (Marktplatz, Ehret-Areal). Von dort ca. 3 Gehminuten.</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-warmes-braun mb-1">Öffentlich</p>
            <p>OEG-Haltestelle „Weinheim Alter OEG-Bahnhof" oder „Weinheim Hauptbahnhof" — jeweils wenige Gehminuten ins Zentrum.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="preise" class="bg-creme px-6 py-16" style="background: #F5EDE0;">
      <div class="max-w-4xl mx-auto">
        <p class="text-xs uppercase tracking-[0.2em] text-warmes-braun mb-3 text-center">Eintrittspreise</p>
        <h2 class="font-display text-2xl text-tiefschwarz text-center mb-8">Preise</h2>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
          {preise.map((p) => (
            <div
              class="bg-off-white border rounded p-4 text-center"
              style={p.highlight
                ? "background: #FAF6EE; border-color: #C9A55C; border-top: 2px solid #C9A55C;"
                : "background: #FAF6EE; border-color: #E5D8C0;"}
            >
              <div class="font-display text-2xl text-kino-rot mb-1">{p.wert}</div>
              <div class="text-[11px] uppercase tracking-widest text-warmes-braun leading-tight">{p.label}</div>
            </div>
          ))}
        </div>

        <p class="text-xs uppercase tracking-widest text-warmes-braun mb-2">Zuschläge & Sonderpreise</p>
        <ul class="text-sm text-tiefschwarz/85 grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
          {zuschlaege.map((z) => (
            <li class="flex items-start gap-2">
              <span class="text-vintage-gold mt-1">·</span>
              <span>{z}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section id="newsletter" class="bg-off-white px-6 py-16" style="background: #FAF6EE;">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-xs uppercase tracking-[0.2em] text-warmes-braun mb-3">Newsletter</p>
        <h2 class="font-display text-2xl text-tiefschwarz mb-3">Kein Filmstart mehr verpassen</h2>
        <p class="text-sm text-tiefschwarz/85 leading-relaxed mb-6">
          Wir informieren Sie über neue Filme, Sonderreihen und Events — ca. einmal pro Woche, jederzeit abbestellbar.
        </p>

        <form class="flex flex-col md:flex-row gap-2 max-w-lg mx-auto">
          <input
            type="email"
            required
            placeholder="Ihre E-Mail-Adresse"
            class="flex-1 border border-vintage-gold/40 rounded px-4 py-2.5 text-sm text-tiefschwarz focus:outline-none focus:border-kino-rot"
            style="background: #F5EDE0;"
          />
          <button
            type="submit"
            class="bg-kino-rot text-creme px-6 py-2.5 rounded font-medium tracking-wider hover:bg-tiefschwarz transition-colors"
          >
            Anmelden
          </button>
        </form>

        <p class="text-xs text-warmes-braun/70 mt-3">
          Die Anmeldung erfolgt über einen Bestätigungslink (Double-Opt-In). Details in der <a href="/datenschutz" class="text-kino-rot underline">Datenschutzerklärung</a>.
        </p>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
