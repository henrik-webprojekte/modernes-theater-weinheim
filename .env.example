# Sanity CMS (Content Management)
SANITY_PROJECT_ID=
SANITY_DATASET=production

# Brevo Newsletter (Double-Opt-In)
# Wird von src/pages/api/newsletter.ts genutzt.
#   BREVO_API_KEY       Brevo-Dashboard -> Settings -> SMTP & API -> API-Keys -> "Generate new key" (v3)
#   BREVO_LIST_ID       Brevo-Dashboard -> Contacts -> Lists -> Newsletter-Liste anklicken -> ID aus URL
#   BREVO_TEMPLATE_ID   Brevo-Dashboard -> Campaigns -> Templates -> Confirmation-Mail-Vorlage anklicken -> ID aus URL
# Die Vorlage muss den DOI-Bestaetigungslink von Brevo enthalten. Brevo liefert den Link
# beim Absenden ueber params, siehe developers.brevo.com/reference/createdoicontact.
# Ohne alle drei Werte gibt /api/newsletter HTTP 501 zurueck.
BREVO_API_KEY=
BREVO_LIST_ID=
BREVO_TEMPLATE_ID=

# Brevo Transactional Email (Vermietungs-Formular)
# Wird von src/pages/api/vermietung.ts genutzt. Nutzt denselben BREVO_API_KEY wie oben.
#   BREVO_SENDER_EMAIL     Absender-Adresse fuer die Anfrage-Mails. MUSS in Brevo verifiziert
#                          sein (Brevo-Dashboard -> Senders & IP -> "Add a sender").
#                          Vorschlag: noreply@kinoweinheim.de
#   BREVO_SENDER_NAME      Anzeigename im Absender-Feld. Default: "Modernes Theater Website"
#   BREVO_VERMIETUNG_TO    Zieladresse. Default: veranstaltung@kinoweinheim.de.
#                          Nur setzen, wenn eine andere Adresse gewuenscht ist.
# Ohne BREVO_API_KEY oder BREVO_SENDER_EMAIL gibt /api/vermietung HTTP 501 zurueck.
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=
BREVO_VERMIETUNG_TO=
