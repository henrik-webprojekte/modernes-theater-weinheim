---
---

<footer class="bg-tiefschwarz text-creme" style="background: #1A1310;">
  <div class="max-w-7xl mx-auto px-4 py-10">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">

      <div class="md:col-span-2">
        <h3 class="font-display text-lg mb-3">Modernes Theater</h3>
        <p class="text-sm text-creme/70 leading-relaxed">
          Hauptstraße 61<br />
          69469 Weinheim<br />
          Tel. <a href="tel:0620162155" class="text-vintage-gold hover:text-creme transition-colors">06201 · 62155</a>
        </p>
      </div>

      <div>
        <p class="text-xs uppercase tracking-widest text-vintage-gold mb-3">Besuch</p>
        <ul class="text-sm text-creme/70 space-y-1.5">
          <li><a href="/programm" class="hover:text-creme transition-colors">Programm</a></li>
          <li><a href="/kontakt#preise" class="hover:text-creme transition-colors">Preise</a></li>
          <li><a href="/kontakt#anfahrt" class="hover:text-creme transition-colors">Anfahrt</a></li>
          <li><a href="/kontakt#newsletter" class="hover:text-creme transition-colors">Newsletter</a></li>
        </ul>
      </div>

      <div>
        <p class="text-xs uppercase tracking-widest text-vintage-gold mb-3">Folgen Sie uns</p>
        <div class="flex gap-3 mb-4">
          <a href="https://www.instagram.com/kinoweinheim/" aria-label="Instagram" class="text-vintage-gold hover:text-creme transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="https://www.tiktok.com/@kinoweinheim" aria-label="TikTok" class="text-vintage-gold hover:text-creme transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.13z"/>
            </svg>
          </a>
          <a href="https://www.facebook.com/kinoweinheim" aria-label="Facebook" class="text-vintage-gold hover:text-creme transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        </div>
        <a href="https://shop.kinoweinheim.de/" class="text-sm text-creme/70 hover:text-creme transition-colors">Shop ↗</a>
      </div>

    </div>

    <div class="pt-6 border-t border-vintage-gold/25 flex flex-col md:flex-row md:justify-between gap-3 text-xs text-creme/50">
      <div>© Woinemer Kino GmbH & Co. KG</div>
      <div class="flex flex-wrap gap-4">
        <a href="/impressum" class="hover:text-vintage-gold transition-colors">Impressum</a>
        <a href="/datenschutz" class="hover:text-vintage-gold transition-colors">Datenschutz</a>
        <button
          type="button"
          data-cookie-reset
          class="hover:text-vintage-gold transition-colors text-left cursor-pointer"
        >Cookie-Einstellungen ändern</button>
      </div>
    </div>

    <script>
      const resetButtons = document.querySelectorAll<HTMLButtonElement>("[data-cookie-reset]")
      resetButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          try {
            localStorage.removeItem("cookie-consent")
          } catch {
            // Privatmodus kann Speicher blockieren
          }
          window.location.reload()
        })
      })
    </script>

  </div>
</footer>