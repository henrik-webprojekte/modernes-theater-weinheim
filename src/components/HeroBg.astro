---
// Foyer-Hintergrundbild für die Hero-Banner der Unterseiten.
// Wird direkt nach dem öffnenden <section>-Tag eingesetzt; die Section
// muss `relative overflow-hidden` sein und der Inhalt danach `relative`,
// damit der Text über dem Bild liegt.
// Etwas kräftigerer Overlay als der Startseiten-Hero, weil die
// Unterseiten-Überschriften keinen text-shadow haben.
import {Image} from "astro:assets"
import heroFoyer from "../assets/hero/foyer-cherie.jpg"
---

<Image
  src={heroFoyer}
  alt=""
  widths={[800, 1200, 1600, 2000]}
  sizes="100vw"
  class="absolute inset-0 w-full h-full object-cover pointer-events-none"
  loading="eager"
  style="opacity: 0.6; object-position: center top;"
/>
<div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(180deg, rgba(26,19,16,0.6) 0%, rgba(26,19,16,0.5) 45%, rgba(26,19,16,0.85) 100%);"></div>
<div class="absolute top-0 left-0 right-0 h-[3px] pointer-events-none" style="background: repeating-linear-gradient(90deg, #C9A55C 0 6px, transparent 6px 12px); opacity: 0.5;"></div>
