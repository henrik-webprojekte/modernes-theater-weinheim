---
import Layout from "../layouts/Layout.astro"
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import {Image} from "astro:assets"
import {
  getSaele,
  getFilmeMitBevorstehendenVorstellungen,
  getKommendeEvents,
  urlFor,
  type Film,
  type Event,
} from "../lib/sanity"
import heroFoyer from "../assets/hero/foyer-cherie.jpg"

const saele = await getSaele()
const dieseWocheFilme = await getFilmeMitBevorstehendenVorstellungen(4)
const kommendeEvents = await getKommendeEvents(3)

const wochentage = ["So", "Mo", "Di", "Mi", "Do", "Fr", "Sa"]

function formatNaechsteVorstellung(film: Film): string {
  const heute = new Date().toISOString().slice(0, 10)
  const kommende = (film.vorstellungen ?? [])
    .filter((v) => v.datum && v.datum >= heute)
    .sort((a, b) =>
      (a.datum ?? "").localeCompare(b.datum ?? "") ||
      (a.uhrzeit ?? "").localeCompare(b.uhrzeit ?? "")
    )
  const v = kommende[0]
  if (!v || !v.datum) return ""
  const wochentag = wochentage[new Date(v.datum).getDay()]
  return `${wochentag} ${v.uhrzeit ?? ""}`.trim()
}

const eventFarben: Record<string, string> = {
  "kaffee-tee-kino": "#8A6B2E",
  "enzo-day": "#6B1818",
  "open-air": "#4A7038",
  "schmittini": "#8A5F2A",
  "sondervorstellung": "#5A3F7F",
  "sonstiges": "#6B4E1F",
}

function formatEventDatum(event: Event): string {
  if (event.wiederkehrend) return event.wiederkehrend
  if (!event.startDatum) return ""
  const opt: Intl.DateTimeFormatOptions = {day: "2-digit", month: "2-digit", year: "numeric"}
  const start = new Date(event.startDatum).toLocaleDateString("de-DE", opt)
  if (!event.endDatum) return start
  const ende = new Date(event.endDatum).toLocaleDateString("de-DE", opt)
  return `${start} – ${ende}`
}
---

<Layout
  title="Modernes Theater Weinheim — Kino, Eventlocation und mehr"
  description="Traditionsreiches Kino in Weinheim, seit 1924. Drei Säle, Kinogarten, aktuelles Filmprogramm und Räume für Firmenevents, Geburtstage und Feiern."
>
  <Header />

  <main id="hauptinhalt">

    {/* 1. Hero */}
    <section class="text-creme relative overflow-hidden" style="background: #1A1310;">
      <div class="hero-foyer-gapfill absolute inset-x-0 top-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <Image
          src={heroFoyer}
          alt=""
          widths={[800, 1200, 1600, 2000]}
          sizes="100vw"
          class="w-full h-auto"
          loading="eager"
          style="opacity: 0.72; object-position: center top;"
        />
      </div>
      <Image
        src={heroFoyer}
        alt=""
        widths={[800, 1200, 1600, 2000, 2600, 3200]}
        sizes="(min-width: 1280px) 130vw, 100vw"
        class="hero-foyer-bg absolute inset-0 w-full h-full object-cover"
        loading="eager"
        style="opacity: 0.72; object-position: center top;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(26,19,16,0.55) 0%, rgba(26,19,16,0.4) 50%, rgba(26,19,16,0.82) 100%);"></div>
      <div class="relative max-w-4xl mx-auto px-6 py-20 md:py-24 text-center">
        <div class="flex items-center justify-center gap-3 md:gap-4 mb-5">
          <span class="h-px w-8 md:w-14 bg-vintage-gold/70" aria-hidden="true"></span>
          <p class="text-xs md:text-sm uppercase tracking-[0.3em] text-vintage-gold whitespace-nowrap">
            Seit 1924 in Weinheim
          </p>
          <span class="h-px w-8 md:w-14 bg-vintage-gold/70" aria-hidden="true"></span>
        </div>
        <h1 class="font-display text-5xl md:text-7xl leading-tight text-creme mb-6" style="text-shadow: 0 2px 20px rgba(0,0,0,0.6);">
          Modernes Theater
        </h1>
        <p class="text-lg md:text-xl text-creme/90 max-w-2xl mx-auto leading-relaxed mb-8" style="text-shadow: 0 1px 8px rgba(0,0,0,0.5);">
          Drei Säle, ein Kinogarten, ein Programm für alle.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a
            href="/programm"
            class="bg-kino-rot text-creme px-6 py-3 rounded font-medium tracking-wider hover:bg-vintage-gold hover:text-tiefschwarz transition-colors"
          >
            Aktuelles Programm
          </a>
          <a
            href="/saele"
            class="border border-vintage-gold text-vintage-gold px-6 py-3 rounded font-medium tracking-wider hover:bg-vintage-gold hover:text-tiefschwarz transition-colors"
          >
            Unsere Säle
          </a>
        </div>
      </div>
    </section>

    {/* 2. Diese Woche im Programm */}
    <section class="bg-off-white px-6 py-16 md:py-20" style="background: #FAF6EE;">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10">
          <p class="text-xs uppercase tracking-[0.3em] text-warmes-braun mb-3">Aktuelles Programm</p>
          <h2 class="font-display text-3xl md:text-4xl leading-tight text-tiefschwarz mb-3">Diese Woche im Kino</h2>
          <p class="text-sm text-tiefschwarz/85 max-w-xl mx-auto">Die nächsten Vorstellungen — direkt aus unserem laufenden Programm.</p>
        </div>

        {dieseWocheFilme.length > 0 && (
          <div class="flex flex-wrap justify-center gap-6 md:gap-8 mb-8">
            {dieseWocheFilme.map((film) => (
              <a href={`/programm/${film.slug.current}`} class="group flex flex-col w-fit">
                <div class="rounded overflow-hidden border border-vintage-gold/40 bg-tiefschwarz mb-3 relative" style="background: #1A1310;">
                  {film.plakat ? (
                    <img
                      src={urlFor(film.plakat).width(500).url()}
                      srcset={`${urlFor(film.plakat).width(300).url()} 300w, ${urlFor(film.plakat).width(500).url()} 500w, ${urlFor(film.plakat).width(700).url()} 700w`}
                      sizes="(max-width: 768px) 40vw, 280px"
                      alt={`Filmplakat: ${film.titel}`}
                      loading="lazy"
                      class="block w-auto h-[240px] md:h-[420px] transition-transform group-hover:scale-[1.02]"
                    />
                  ) : (
                    <div class="w-[160px] md:w-[280px] aspect-[2/3] flex items-center justify-center text-vintage-gold/80 text-[10px] uppercase tracking-widest text-center px-2">Kein Plakat</div>
                  )}
                  {film.istNeu && (
                    <span class="absolute top-2 left-2 bg-kino-rot text-creme text-[10px] uppercase tracking-widest px-2 py-0.5 rounded">Neu</span>
                  )}
                </div>
                <h3 class="font-display text-base md:text-lg text-tiefschwarz leading-tight mb-1 group-hover:text-kino-rot transition-colors">{film.titel}</h3>
                <p class="text-xs uppercase tracking-widest text-warmes-braun">
                  {formatNaechsteVorstellung(film)}
                </p>
              </a>
            ))}
          </div>
        )}

        {dieseWocheFilme.length === 0 && (
          <div class="bg-creme border border-vintage-gold/40 rounded p-8 text-center max-w-lg mx-auto mb-8" style="background: #F5EDE0;">
            <p class="text-sm text-warmes-braun italic">
              Für die nächsten Tage sind noch keine Vorstellungen eingetragen — einen Blick auf kommende Filme und Termine lohnt sich trotzdem.
            </p>
          </div>
        )}

        <div class="text-center">
          <a href="/programm" class="inline-flex items-center gap-2 text-sm text-kino-rot border-b border-vintage-gold/60 pb-0.5 hover:text-tiefschwarz transition-colors">
            <span>Alle Filme dieser Woche ansehen</span>
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    {/* 3. Reservierungs-Zeile */}
    <section class="bg-kino-rot text-creme px-6 py-8 md:py-10" style="background: #6B1818;">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4 text-center md:text-left">
        <div class="flex items-center gap-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-vintage-gold">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-vintage-gold mb-1">Karten reservieren</p>
            <p class="font-display text-2xl md:text-3xl leading-tight">Kostenlos während der Öffnungszeiten</p>
            <p class="text-sm text-creme/90 mt-1">Telefonisch oder direkt an unserer Kinokasse.</p>
          </div>
        </div>
        <a
          href="tel:0620162155"
          class="bg-vintage-gold text-tiefschwarz px-6 py-3 rounded font-display text-lg tracking-wider hover:bg-creme transition-colors whitespace-nowrap"
        >
          06201 · 62155
        </a>
      </div>
    </section>

    {/* 3.5 Spar-Tage der Woche */}
    <section class="bg-off-white px-6 py-10 md:py-12" style="background: #FAF6EE;">
      <div class="max-w-4xl mx-auto">
        <p class="text-xs uppercase tracking-[0.3em] text-warmes-braun mb-5 text-center">Regelmäßig bei uns</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-4xl mx-auto">
          <div class="bg-creme border rounded p-4 md:p-5 flex items-center gap-4" style="background: #F5EDE0; border-color: #E5D8C0; border-top: 2px solid #C9A55C;">
            <div class="font-display text-3xl md:text-4xl text-kino-rot leading-none shrink-0">7 €</div>
            <div>
              <p class="font-display text-lg md:text-xl text-tiefschwarz leading-tight">Kinotag</p>
              <p class="text-xs uppercase tracking-widest text-warmes-braun mt-1">Jeden Dienstag</p>
            </div>
          </div>
          <div class="bg-creme border rounded p-4 md:p-5 flex items-center gap-4" style="background: #F5EDE0; border-color: #E5D8C0; border-top: 2px solid #C9A55C;">
            <div class="font-display text-3xl md:text-4xl text-kino-rot leading-none shrink-0">7 €</div>
            <div>
              <p class="font-display text-lg md:text-xl text-tiefschwarz leading-tight">Starttag</p>
              <p class="text-xs uppercase tracking-widest text-warmes-braun mt-1">Jeden Donnerstag</p>
            </div>
          </div>
          <a href="/events/kaffee-tee-kino" class="bg-creme border rounded p-4 md:p-5 flex items-center gap-4 hover:shadow-md transition-shadow" style="background: #F5EDE0; border-color: #E5D8C0; border-top: 2px solid #8A6B2E;">
            <div class="font-display text-3xl md:text-4xl text-kino-rot leading-none shrink-0">8 €</div>
            <div>
              <p class="font-display text-lg md:text-xl text-tiefschwarz leading-tight">Kaffee-Tee-Kino</p>
              <p class="text-xs uppercase tracking-widest text-warmes-braun mt-1">Jeden 1. Mittwoch · inkl. Kaffee & Kuchen</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    {kommendeEvents.length > 0 && (
      <section class="bg-creme px-6 py-16 md:py-20" style="background: #F5EDE0;">
        <div class="max-w-5xl mx-auto">
          <div class="text-center mb-10">
            <p class="text-xs uppercase tracking-[0.3em] text-warmes-braun mb-3">Neben dem Kinoprogramm</p>
            <h2 class="font-display text-3xl md:text-4xl leading-tight text-tiefschwarz mb-3">Nächste Höhepunkte</h2>
            <p class="text-sm text-tiefschwarz/85 max-w-xl mx-auto">Sonderreihen, Events und Termine, auf die man sich freuen darf.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            {kommendeEvents.map((event) => {
              const farbe = eventFarben[event.kategorie] ?? "#6B4E1F"
              return (
                <article class="bg-off-white border border-vintage-gold/20 rounded p-5" style={`background: #FAF6EE; border-top: 3px solid ${farbe};`}>
                  <p class="text-[10px] uppercase tracking-[0.2em] mb-2" style={`color: ${farbe};`}>{formatEventDatum(event)}</p>
                  <h3 class="font-display text-xl text-tiefschwarz mb-2 leading-tight">{event.titel}</h3>
                  {event.kurzbeschreibung && (
                    <p class="text-sm text-tiefschwarz/85 leading-relaxed">{event.kurzbeschreibung}</p>
                  )}
                </article>
              )
            })}
          </div>

          <div class="text-center">
            <a href="/events" class="inline-flex items-center gap-2 text-sm text-kino-rot border-b border-vintage-gold/60 pb-0.5 hover:text-tiefschwarz transition-colors">
              <span>Alle Sonderreihen und Events</span>
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </section>
    )}

    {/* 5. Säle */}
    <section class="bg-off-white px-6 py-16 md:py-20" style="background: #FAF6EE;">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-xs uppercase tracking-[0.3em] text-warmes-braun mb-3">
          Drei Häuser unter einem Dach
        </p>
        <h2 class="font-display text-3xl md:text-4xl leading-tight text-tiefschwarz mb-3">
          Unsere Säle
        </h2>
        <p class="text-sm text-tiefschwarz/85 max-w-2xl mx-auto leading-relaxed mb-10">
          Jeder Saal hat seinen eigenen Charakter — vom klassischen Vorhang bis zur
          Premium-Lounge.
        </p>

        {saele.length === 0 && (
          <div class="bg-creme border border-vintage-gold/50 rounded p-8 max-w-lg mx-auto" style="background: #F5EDE0;">
            <p class="text-warmes-braun italic text-sm">
              Noch keine Säle in Sanity angelegt.
            </p>
          </div>
        )}

        {saele.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            {saele.slice(0, 3).map((saal) => (
              <a
                href={`/saele#${saal.slug.current}`}
                class="bg-tiefschwarz text-creme p-6 rounded text-left border-t-2 hover:opacity-90 transition-opacity"
                style={`background: #1A1310; border-top-color: ${saal.farbakzent ?? "#C9A55C"};`}
              >
                <h3 class="font-display text-2xl md:text-3xl mb-2">{saal.name}</h3>
                <p
                  class="text-xs uppercase tracking-widest mb-3"
                  style={`color: ${saal.farbakzent ?? "#C9A55C"};`}
                >
                  {saal.plaetze} Plätze
                </p>
                {saal.kurzbeschreibung && (
                  <p class="text-sm text-creme/80 leading-relaxed">
                    {saal.kurzbeschreibung}
                  </p>
                )}
              </a>
            ))}
          </div>
        )}

        <a href="/saele" class="inline-flex items-center gap-2 text-sm text-kino-rot border-b border-vintage-gold/60 pb-0.5 hover:text-tiefschwarz transition-colors">
          <span>Alle Säle im Detail</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    {/* 6. Für besondere Anlässe */}
    <section class="bg-creme px-6 py-16 md:py-20" style="background: #F5EDE0;">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10">
          <p class="text-xs uppercase tracking-[0.3em] text-warmes-braun mb-3">Ihr Anlass, unser Ort</p>
          <h2 class="font-display text-3xl md:text-4xl leading-tight text-tiefschwarz mb-3">Für besondere Anlässe</h2>
          <p class="text-sm text-tiefschwarz/85 max-w-2xl mx-auto leading-relaxed">
            Ob eigenes Fest mit Filmvorführung oder Gruppen-Besuch im laufenden Programm — wir richten uns nach Ihrem Anlass.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
          <article class="bg-off-white border border-vintage-gold/20 rounded p-6" style="background: #FAF6EE; border-top: 3px solid #6B1818;">
            <p class="text-[10px] uppercase tracking-[0.2em] mb-2 text-kino-rot">Ganzer Saal exklusiv</p>
            <h3 class="font-display text-xl text-tiefschwarz mb-2 leading-tight hyphens-auto">Vermietung</h3>
            <p class="text-sm text-tiefschwarz/85 leading-relaxed mb-3">Firmenevents, Geburtstage, Vereinsfeiern — mit Catering, Kinogarten und Blick auf die Windeck.</p>
            <a href="/vermietung" class="text-xs text-kino-rot border-b border-vintage-gold/60 pb-0.5 hover:text-tiefschwarz transition-colors">Anfrage senden →</a>
          </article>

          <article class="bg-off-white border border-vintage-gold/20 rounded p-6" style="background: #FAF6EE; border-top: 3px solid #6B4E1F;">
            <p class="text-[10px] uppercase tracking-[0.2em] mb-2 text-warmes-braun">Für Gruppen im Programm</p>
            <h3 class="font-display text-xl text-tiefschwarz mb-2 leading-tight hyphens-auto">Sondervorstellungen</h3>
            <p class="text-sm text-tiefschwarz/85 leading-relaxed mb-3">Schulklassen, Betriebsausflüge, private Runden: flexible Vorstellungen einzelner Filme — auch außerhalb der regulären Zeiten.</p>
            <a href="tel:0620162155" class="text-xs text-kino-rot border-b border-vintage-gold/60 pb-0.5 hover:text-tiefschwarz transition-colors">Anrufen: 06201 · 62155 →</a>
          </article>

          <article class="bg-off-white border border-vintage-gold/20 rounded p-6" style="background: #FAF6EE; border-top: 3px solid #4A7038;">
            <p class="text-[10px] uppercase tracking-[0.2em] mb-2" style="color: #4A7038;">Von Frühling bis Herbst</p>
            <h3 class="font-display text-xl text-tiefschwarz mb-2 leading-tight hyphens-auto">Kinogarten</h3>
            <p class="text-sm text-tiefschwarz/85 leading-relaxed mb-3">Achtzig Quadratmeter unter freiem Himmel, mit Bühne und Bar — für private Veranstaltungen oder als Zusatz zum Saal.</p>
            <a href="/saele#kinogarten" class="text-xs text-kino-rot border-b border-vintage-gold/60 pb-0.5 hover:text-tiefschwarz transition-colors">Zum Kinogarten →</a>
          </article>

          <article class="bg-off-white border border-vintage-gold/20 rounded p-6" style="background: #FAF6EE; border-top: 3px solid #8A5F2A;">
            <p class="text-[10px] uppercase tracking-[0.2em] mb-2" style="color: #8A5F2A;">Verschenken statt schenken</p>
            <h3 class="font-display text-xl text-tiefschwarz mb-2 leading-tight hyphens-auto">Gutscheine im Shop</h3>
            <p class="text-sm text-tiefschwarz/85 leading-relaxed mb-3">Kinogutscheine für jeden Anlass — als Wertgutschein oder für bestimmte Filme. Einlösbar an der Kasse und für Vermietungen.</p>
            <a href="https://shop.kinoweinheim.de/" target="_blank" rel="noopener" class="text-xs text-kino-rot border-b border-vintage-gold/60 pb-0.5 hover:text-tiefschwarz transition-colors">Zum Shop ↗</a>
          </article>
        </div>
      </div>
    </section>

    {/* 7. Newsletter + Social */}
    <section class="bg-tiefschwarz text-creme px-6 py-14 md:py-16" style="background: #1A1310;">
      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-start">

        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-vintage-gold mb-3">Kein Filmstart mehr verpassen</p>
          <h2 class="font-display text-2xl md:text-3xl leading-tight text-creme mb-3">Unser Newsletter</h2>
          <p class="text-sm text-creme/85 leading-relaxed mb-5">
            Ca. einmal pro Woche neue Filme, Sonderreihen und Events direkt ins Postfach — jederzeit abbestellbar.
          </p>
          <form id="home-newsletter-form" class="flex flex-col sm:flex-row gap-2" novalidate>
            <label for="home-newsletter-email" class="sr-only">Ihre E-Mail-Adresse für den Newsletter</label>
            <input
              id="home-newsletter-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="Ihre E-Mail-Adresse"
              class="flex-1 min-w-0 border border-vintage-gold/40 rounded px-4 py-2.5 text-sm text-creme bg-transparent focus:border-vintage-gold placeholder:text-creme/50"
            />
            <button
              id="home-newsletter-submit"
              type="submit"
              class="bg-kino-rot text-creme px-5 py-2.5 rounded font-medium tracking-wider hover:bg-vintage-gold hover:text-tiefschwarz transition-colors shrink-0"
            >
              <span data-idle>Anmelden</span>
              <span data-loading class="hidden">Wird gesendet …</span>
            </button>
          </form>
          <p id="home-newsletter-status" role="status" aria-live="polite" class="mt-3 text-xs text-creme/85"></p>
          <p class="text-xs text-creme/60 italic mt-3">
            Mit der Anmeldung stimmen Sie unserer <a href="/datenschutz" class="text-vintage-gold hover:text-creme underline">Datenschutzerklärung</a> zu. Doppel-Opt-In per Bestätigungsmail.
          </p>

          <script>
            const form = document.getElementById("home-newsletter-form") as HTMLFormElement | null
            const input = document.getElementById("home-newsletter-email") as HTMLInputElement | null
            const btn = document.getElementById("home-newsletter-submit") as HTMLButtonElement | null
            const status = document.getElementById("home-newsletter-status")
            const idleLabel = btn?.querySelector<HTMLElement>("[data-idle]")
            const loadingLabel = btn?.querySelector<HTMLElement>("[data-loading]")

            function setLoading(loading: boolean) {
              if (!btn || !idleLabel || !loadingLabel) return
              btn.disabled = loading
              idleLabel.classList.toggle("hidden", loading)
              loadingLabel.classList.toggle("hidden", !loading)
            }

            function zeigeStatus(msg: string, err: boolean) {
              if (!status) return
              status.textContent = msg
              status.classList.toggle("text-vintage-gold", err)
              status.classList.toggle("text-creme/85", !err)
            }

            form?.addEventListener("submit", async (e) => {
              e.preventDefault()
              const email = (input?.value ?? "").trim()
              if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                zeigeStatus("Bitte geben Sie eine gültige E-Mail-Adresse ein.", true)
                input?.focus()
                return
              }
              setLoading(true)
              zeigeStatus("", false)
              try {
                const res = await fetch("/api/newsletter", {
                  method: "POST",
                  headers: {"content-type": "application/json"},
                  body: JSON.stringify({email}),
                })
                const data = await res.json().catch(() => ({ok: false, message: "Unerwartete Antwort."}))
                if (res.ok && data.ok) {
                  form.classList.add("hidden")
                  zeigeStatus("Fast geschafft! Wir haben Ihnen eine Bestätigungsmail geschickt. Bitte klicken Sie den Link darin.", false)
                } else {
                  zeigeStatus(data.message ?? "Etwas ist schiefgelaufen. Bitte später erneut versuchen.", true)
                }
              } catch {
                zeigeStatus("Verbindung zum Server fehlgeschlagen. Bitte später erneut versuchen.", true)
              } finally {
                setLoading(false)
              }
            })
          </script>
