---
const nav = [
  {label: "Start", href: "/"},
  {label: "Programm", href: "/programm"},
  {label: "Säle", href: "/saele"},
  {label: "Vermietung", href: "/vermietung"},
  {label: "Events", href: "/events"},
  {label: "Historie", href: "/historie"},
  {label: "Kontakt", href: "/kontakt"},
]

const currentPath = Astro.url.pathname

const navLinks = nav.slice(0, 3)
const navRechts = nav.slice(3)
---

<header class="bg-tiefschwarz text-creme border-b border-vintage-gold/50 relative" style="background: #1A1310;">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center gap-4">

    <a href="/" class="flex items-center shrink-0 group" aria-label="Modernes Theater — zur Startseite">
      <span class="bg-creme rounded-sm px-2 py-1 inline-flex items-center transition-transform group-hover:scale-[1.03]">
        <img
          src="/logos/modernes-theater-logo.png"
          alt="Modernes Theater 3D"
          class="h-12 lg:h-14 w-auto"
        />
      </span>
    </a>

    <nav class="hidden md:flex flex-1 items-center justify-center gap-5 text-xs tracking-wider">
      {navLinks.map((item) => (
        <a
          href={item.href}
          class:list={[
            "relative hover:text-vintage-gold transition-colors py-1",
            currentPath === item.href
              ? "text-vintage-gold after:absolute after:left-0 after:right-0 after:-bottom-0.5 after:h-px after:bg-vintage-gold"
              : "text-creme",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden md:block w-36 lg:w-44 shrink-0" aria-hidden="true"></div>

    <nav class="hidden md:flex flex-1 items-center justify-center gap-5 text-xs tracking-wider">
      {navRechts.map((item) => (
        <a
          href={item.href}
          class:list={[
            "relative hover:text-vintage-gold transition-colors py-1",
            currentPath === item.href
              ? "text-vintage-gold after:absolute after:left-0 after:right-0 after:-bottom-0.5 after:h-px after:bg-vintage-gold"
              : "text-creme",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href="tel:0620162155"
      class="hidden md:flex items-center gap-2 text-xs text-vintage-gold hover:text-creme transition-colors shrink-0"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      06201 · 62155
    </a>

    <button
      id="menu-toggle"
      type="button"
      class="md:hidden text-creme p-1 ml-auto"
      aria-label="Menü öffnen"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

  </div>

  <img
    src="/logos/vintage-rauten.png"
    alt=""
    aria-hidden="true"
    class="hidden md:block absolute left-1/2 bottom-0 -translate-x-1/2 translate-y-1/2 h-32 lg:h-40 w-auto pointer-events-none z-20 drop-shadow-[0_6px_10px_rgba(0,0,0,0.55)]"
  />
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-50 hidden md:hidden flex-col text-creme"
  style="background: #1A1310;"
  role="dialog"
  aria-modal="true"
  aria-label="Hauptmenü"
>
  <div class="h-[3px] shrink-0" style="background: repeating-linear-gradient(90deg, #C9A55C 0 6px, transparent 6px 12px); opacity: 0.6;"></div>

  <div class="flex items-center justify-between px-4 py-3 border-b border-vintage-gold/30">
    <span class="bg-creme rounded-sm px-2 py-1 inline-flex items-center">
      <img src="/logos/modernes-theater-logo.png" alt="Modernes Theater 3D" class="h-10 w-auto" />
    </span>

    <button
      id="menu-close"
      type="button"
      class="text-creme p-2 -mr-2"
      aria-label="Menü schließen"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <nav class="flex-1 flex flex-col items-center justify-center gap-1 px-6">
    {nav.map((item) => (
      <a
        href={item.href}
        class:list={[
          "font-display text-3xl py-3 tracking-wide transition-colors",
          currentPath === item.href ? "text-vintage-gold" : "text-creme hover:text-vintage-gold",
        ]}
      >
        {item.label}
      </a>
    ))}
  </nav>

  <div class="px-6 pb-8 pt-6 border-t border-vintage-gold/30">
    <a
      href="tel:0620162155"
      class="flex items-center justify-center gap-3 text-vintage-gold hover:text-creme transition-colors mb-4"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      <span class="text-lg tracking-wider">06201 · 62155</span>
    </a>

    <p class="text-center text-sm text-creme/70 leading-relaxed mb-5">
      Hauptstraße 61<br />
      69469 Weinheim
    </p>

    <div class="flex items-center justify-center gap-5">
      <a href="https://www.instagram.com/kinoweinheim/" aria-label="Instagram" class="text-vintage-gold hover:text-creme transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
      </a>
      <a href="https://www.tiktok.com/@kinoweinheim" aria-label="TikTok" class="text-vintage-gold hover:text-creme transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.13z"/>
        </svg>
      </a>
      <a href="https://www.facebook.com/kinoweinheim" aria-label="Facebook" class="text-vintage-gold hover:text-creme transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="h-[3px] shrink-0" style="background: repeating-linear-gradient(90deg, #C9A55C 0 6px, transparent 6px 12px); opacity: 0.6;"></div>
</div>

<script>
  const toggleBtn = document.getElementById("menu-toggle");
  const closeBtn = document.getElementById("menu-close");
  const menu = document.getElementById("mobile-menu");

  function openMenu() {
    if (!menu || !toggleBtn) return;
    menu.classList.remove("hidden");
    menu.classList.add("flex");
    toggleBtn.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    if (!menu || !toggleBtn) return;
    menu.classList.add("hidden");
    menu.classList.remove("flex");
    toggleBtn.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  toggleBtn?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && menu && !menu.classList.contains("hidden")) {
      closeMenu();
    }
  });

  menu?.querySelectorAll("a[href]").forEach((link) => {
    link.addEventListener("click", (event) => {
      const href = link.getAttribute("href") ?? "";
      if (href.startsWith("#") || href.startsWith("tel:") || href.startsWith("mailto:")) return;
      closeMenu();
    });
  });
</script>
