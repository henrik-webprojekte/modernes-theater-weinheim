---
import "../styles/global.css";
import CookieBanner from "../components/CookieBanner.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Modernes Theater Weinheim",
  description = "Kino, Eventlocation und mehr — seit 1924 in der Weinheimer Innenstadt."
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Limelight&family=Source+Sans+3:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-creme text-tiefschwarz font-sans antialiased">
    <slot />
    <CookieBanner />
  </body>
</html>