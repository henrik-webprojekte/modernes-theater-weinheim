---
---

<div
  id="cookie-banner"
  class="fixed inset-x-0 bottom-0 z-40 hidden"
  role="dialog"
  aria-label="Cookie-Hinweis"
  aria-live="polite"
>
  <div class="relative">
    <div class="absolute -top-[3px] left-0 right-0 h-[3px]" style="background: repeating-linear-gradient(90deg, #C9A55C 0 6px, transparent 6px 12px); opacity: 0.6;"></div>

    <div class="bg-tiefschwarz text-creme border-t border-vintage-gold/30 shadow-[0_-8px_20px_rgba(0,0,0,0.4)]" style="background: #1A1310;">
      <div class="max-w-5xl mx-auto px-6 py-5 md:py-4 flex flex-col md:flex-row md:items-center gap-4">

        <div class="flex-1 min-w-0">
          <p class="text-xs uppercase tracking-[0.2em] text-vintage-gold mb-1">Datenschutz</p>
          <p class="text-sm text-creme/85 leading-relaxed">
            Wir nutzen technisch notwendige Cookies, damit die Seite funktioniert. Optional dürfen wir Nutzungsstatistiken erheben, um die Seite zu verbessern. Mehr in unserer <a href="/datenschutz" class="text-vintage-gold underline hover:text-creme transition-colors">Datenschutzerklärung</a>.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-2 shrink-0">
          <button
            id="cookie-essential"
            type="button"
            class="border border-vintage-gold/60 text-vintage-gold hover:bg-vintage-gold/10 px-4 py-2 rounded text-xs tracking-widest uppercase transition-colors whitespace-nowrap"
          >
            Nur notwendige
          </button>
          <button
            id="cookie-all"
            type="button"
            class="bg-kino-rot text-creme hover:bg-vintage-gold hover:text-tiefschwarz px-4 py-2 rounded text-xs tracking-widest uppercase transition-colors whitespace-nowrap"
          >
            Alle akzeptieren
          </button>
        </div>

      </div>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById("cookie-banner")
  const btnAll = document.getElementById("cookie-all")
  const btnEssential = document.getElementById("cookie-essential")

  const STORAGE_KEY = "cookie-consent"

  function showBanner() {
    if (!banner) return
    banner.classList.remove("hidden")
  }

  function hideBanner() {
    if (!banner) return
    banner.classList.add("hidden")
  }

  function saveChoice(value: string) {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({value, timestamp: Date.now()}))
    } catch {
      // localStorage kann in Privatmodus blockiert sein — kein Weltuntergang
    }
    hideBanner()
  }

  const stored = (() => {
    try {
      return localStorage.getItem(STORAGE_KEY)
    } catch {
      return null
    }
  })()

  if (!stored) {
    showBanner()
  }

  btnAll?.addEventListener("click", () => saveChoice("all"))
  btnEssential?.addEventListener("click", () => saveChoice("essential"))
</script>
