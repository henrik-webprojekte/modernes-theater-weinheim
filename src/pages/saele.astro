---
import Layout from "../layouts/Layout.astro"
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import ScrollToTop from "../components/ScrollToTop.astro"
import {getSaele, urlFor, type Saal} from "../lib/sanity"
import {toHTML} from "@portabletext/to-html"

const saele = await getSaele()

function hexZuTextfarben(dunkel: boolean, accent: string) {
  return {
    kicker: dunkel ? accent : "#6B4E1F",
    charakter: dunkel ? accent : "#6B1818",
    text: dunkel ? "#C9BAA0" : "#4A3814",
    name: dunkel ? "#F5EDE0" : "#1A1310",
    tileBg: dunkel ? "rgba(255,255,255,0.06)" : "#FAF6EE",
    tileBorder: dunkel ? "" : "0.5px solid #E5D8C0",
  }
}
---

<Layout
  title="Unsere Säle — Modernes Theater Weinheim"
  description="Drei Kinosäle mit eigenem Charakter: Chic (201 Plätze mit Balkon), Cherie (Premium-Lounge, 74) und Charme (klein & gemütlich, 70) — plus Kinogarten unter freiem Himmel."
>
  <Header />

  <main id="hauptinhalt">

    <section class="bg-tiefschwarz text-creme relative" style="background: #1A1310;">
      <div class="absolute top-0 left-0 right-0 h-[3px]" style="background: repeating-linear-gradient(90deg, #C9A55C 0 6px, transparent 6px 12px); opacity: 0.5;"></div>
      <div class="max-w-4xl mx-auto px-6 py-20 md:py-24 text-center">
        <p class="text-xs uppercase tracking-[0.3em] text-vintage-gold mb-3">
          Drei Häuser unter einem Dach
        </p>
        <h1 class="font-display text-4xl md:text-6xl leading-tight text-creme mb-4">
          Unsere Säle
        </h1>
        <p class="text-base text-creme/80 max-w-2xl mx-auto leading-relaxed mb-8">
          Chic für das große Kino-Erlebnis. Cherie für den intimen Abend. Charme für den entspannten Filmgenuss. Und ein Kinogarten für die warme Jahreszeit.
        </p>
        {saele.length > 0 && (
          <div class="flex flex-wrap justify-center gap-3">
            {saele.map((saal) => (
              <a
                href={`#${saal.slug.current}`}
                class="text-xs tracking-widest border rounded px-3 py-1.5 hover:bg-vintage-gold/10 transition-colors"
                style={`color: ${saal.farbakzent ?? "#C9A55C"}; border-color: ${saal.farbakzent ?? "#C9A55C"}`}
              >
                {saal.name} ↓
              </a>
            ))}
          </div>
        )}
      </div>
    </section>

    {saele.length === 0 && (
      <section class="bg-creme px-6 py-16" style="background: #F5EDE0;">
        <div class="bg-off-white border border-vintage-gold/40 rounded p-10 max-w-2xl mx-auto text-center" style="background: #FAF6EE;">
          <p class="font-display text-xl text-tiefschwarz mb-3">Noch keine Säle angelegt</p>
          <p class="text-sm text-tiefschwarz/85 leading-relaxed">
            Sobald im Sanity-Studio unter „Saal" der erste Eintrag angelegt und veröffentlicht ist, erscheint er hier automatisch.
          </p>
        </div>
      </section>
    )}

    {saele.map((saal: Saal, i: number) => {
      const dunkel = saal.dunklerHintergrund ?? false
      const accent = saal.farbakzent ?? "#C9A55C"
      const hintergrund = saal.hintergrundFarbe ?? "#F5EDE0"
      const bildLinks = i % 2 === 0
      const farben = hexZuTextfarben(dunkel, accent)
      const beschreibungHtml = saal.beschreibungLang
        ? toHTML(saal.beschreibungLang as never)
        : ""
      const bildUrl = saal.bild ? urlFor(saal.bild).width(1200).url() : null
      const bildSrcset = saal.bild
        ? `${urlFor(saal.bild).width(600).url()} 600w, ${urlFor(saal.bild).width(900).url()} 900w, ${urlFor(saal.bild).width(1200).url()} 1200w`
        : ""
      return (
        <section id={saal.slug.current} class="px-6 py-16 md:py-20" style={`background: ${hintergrund};`}>
          <div class={`max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center ${bildLinks ? "" : "md:[direction:rtl]"}`}>

            <div class={bildLinks ? "" : "md:[direction:ltr]"}>
              {bildUrl ? (
                <div class="rounded border overflow-hidden" style={`border-color: ${accent};`}>
                  <img
                    src={bildUrl}
                    srcset={bildSrcset}
                    sizes="(max-width: 768px) 100vw, 50vw"
                    alt={`Saal ${saal.name}`}
                    loading="lazy"
                    class="block w-full h-auto"
                  />
                </div>
              ) : (
                <div class="aspect-[4/3] rounded border overflow-hidden relative" style={`border-color: ${accent}; background: ${dunkel ? "#2A1A3A" : "#4A2818"};`}>
                  <div class="absolute inset-0" style={`background: radial-gradient(ellipse at 40% 30%, ${accent}44 0%, transparent 70%);`}></div>
                  <div class="absolute bottom-3 left-0 right-0 text-center text-[10px] uppercase tracking-widest text-creme/85">
                    Foto {saal.name}
                  </div>
                </div>
              )}
            </div>

            <div class={bildLinks ? "" : "md:[direction:ltr]"}>
              {saal.kicker && (
                <p class="text-xs uppercase tracking-[0.3em] mb-2" style={`color: ${farben.kicker};`}>{saal.kicker}</p>
              )}
              <h2 class="font-display text-4xl md:text-5xl leading-tight mb-2" style={`color: ${farben.name};`}>{saal.name}</h2>
              {saal.charakterUntertitel && (
                <p class="italic text-sm md:text-base mb-4" style={`color: ${farben.charakter};`}>{saal.charakterUntertitel}</p>
              )}
              {saal.kurzbeschreibung && (
                <p class="text-sm md:text-base leading-relaxed mb-6" style={`color: ${farben.text};`}>{saal.kurzbeschreibung}</p>
              )}

              {saal.fakten && saal.fakten.length > 0 && (
                <div class={`grid gap-2 mb-4 ${saal.fakten.length === 1 ? "grid-cols-1" : saal.fakten.length === 2 ? "grid-cols-2" : "grid-cols-3"}`}>
                  {saal.fakten.map((fakt) => (
                    <div
                      class="rounded p-2 sm:p-2.5 text-center min-w-0"
                      style={dunkel
                        ? `background: ${farben.tileBg}; border-top: 2px solid ${accent};`
                        : `background: ${farben.tileBg}; border: ${farben.tileBorder}; border-top: 2px solid ${accent};`}
                    >
                      <div class="font-display text-sm sm:text-base md:text-xl leading-tight break-words" style={`color: ${farben.name};`}>{fakt.wert}</div>
                      <div class="text-[10px] uppercase tracking-widest mt-1 break-words" style={`color: ${dunkel ? accent : "#6B4E1F"};`}>{fakt.label}</div>
                    </div>
                  ))}
                </div>
              )}

              {saal.technik && (
                <>
                  <p class="text-[10px] uppercase tracking-[0.2em] mb-1" style={`color: ${farben.kicker};`}>Technik</p>
                  <p class="text-xs md:text-sm leading-relaxed" style={`color: ${farben.text};`}>{saal.technik}</p>
                </>
              )}
            </div>

          </div>

          {beschreibungHtml && (
            <div class={`saal-beschreibung max-w-3xl mx-auto mt-10 md:mt-12 ${dunkel ? "saal-beschreibung--dunkel" : ""}`} style={`color: ${farben.text};`} set:html={beschreibungHtml}></div>
          )}
        </section>
      )
    })}

    <section class="bg-kino-rot text-creme px-6 py-16 text-center" style="background: #6B1818;">
      <div class="max-w-3xl mx-auto">
        <p class="text-xs uppercase tracking-[0.3em] text-creme/70 mb-3">
          Alle Räume auch buchbar
        </p>
        <h2 class="font-display text-3xl md:text-4xl leading-tight mb-4">
          Feiern Sie bei uns
        </h2>
        <p class="text-base text-creme/85 max-w-xl mx-auto leading-relaxed mb-6">
          Ob Firmenevent, Geburtstag oder Vereinsfeier — wir vermieten unsere Säle und den Kinogarten für Ihre Veranstaltung.
        </p>
        <a
          href="/vermietung"
          class="inline-block border border-vintage-gold text-creme px-6 py-3 rounded font-medium tracking-wider hover:bg-vintage-gold hover:text-tiefschwarz transition-colors"
        >
          Zur Vermietung
        </a>
      </div>
    </section>

  </main>

  <Footer />
  <ScrollToTop />
</Layout>

<style>
  .saal-beschreibung :global(p) {
    margin-bottom: 1rem;
    line-height: 1.65;
  }
  .saal-beschreibung :global(h2) {
    font-family: "Limelight", serif;
    font-size: 1.5rem;
    line-height: 1.2;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .saal-beschreibung :global(h3) {
    font-family: "Limelight", serif;
    font-size: 1.25rem;
    line-height: 1.25;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }
  .saal-beschreibung :global(a) {
    color: #6B1818;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(201, 165, 92, 0.6);
  }
  .saal-beschreibung--dunkel :global(a) {
    color: #F5EDE0;
    text-decoration-color: #C9A55C;
  }
  .saal-beschreibung :global(strong) {
    font-weight: 600;
  }
  .saal-beschreibung :global(em) {
    font-style: italic;
  }
  .saal-beschreibung :global(ul),
  .saal-beschreibung :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }
  .saal-beschreibung :global(ul) {
    list-style: disc;
  }
  .saal-beschreibung :global(ol) {
    list-style: decimal;
  }
  .saal-beschreibung :global(li) {
    margin-bottom: 0.35rem;
  }
  .saal-beschreibung :global(blockquote) {
    border-left: 3px solid #C9A55C;
    padding-left: 1rem;
    margin: 1.25rem 0;
    font-style: italic;
  }
</style>
