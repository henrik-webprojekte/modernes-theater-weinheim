---
import Layout from "../layouts/Layout.astro"
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import {Image} from "astro:assets"
import {getSaele} from "../lib/sanity"
import heroFoyer from "../assets/hero/art-deco-foyer.jpg"

const saele = await getSaele()
const reihenfolge = ["chic", "cherie", "charme", "kinogarten"]
const sortierteSaele = [...saele].sort((a, b) => {
  const ai = reihenfolge.indexOf(a.slug.current)
  const bi = reihenfolge.indexOf(b.slug.current)
  return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi)
})

const schritte = [
  {nummer: 1, titel: "Anfrage senden", text: "Ihre Wünsche in wenigen Feldern"},
  {nummer: 2, titel: "Termin & Angebot", text: "Wir melden uns mit Details"},
  {nummer: 3, titel: "Ablauf besprechen", text: "Catering, Technik, Programm"},
  {nummer: 4, titel: "Ihren Abend genießen", text: "Zurücklehnen und feiern"},
]
---

<Layout
  title="Vermietung — Modernes Theater Weinheim"
  description="Kinosaal mieten in Weinheim: Firmenevents, Geburtstage, Vereinsfeiern. Drei Säle und ein Kinogarten mit Bühne und Bar — mit Catering und Kinoerlebnis."
>
  <Header />

  <main id="hauptinhalt">

    <section class="text-creme relative overflow-hidden" style="background: #1A1310;">
      <Image
        src={heroFoyer}
        alt=""
        widths={[800, 1200, 1600]}
        sizes="100vw"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        style="opacity: 0.28;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(26,19,16,0.55) 0%, rgba(26,19,16,0.8) 100%);"></div>
      <div class="absolute top-0 left-0 right-0 h-[3px]" style="background: repeating-linear-gradient(90deg, #C9A55C 0 6px, transparent 6px 12px); opacity: 0.6;"></div>
      <div class="relative max-w-4xl mx-auto px-6 py-20 md:py-24 text-center">
        <p class="text-xs uppercase tracking-[0.3em] text-vintage-gold mb-3">
          Ihr Anlass, unser Ort
        </p>
        <h1 class="font-display text-4xl md:text-6xl leading-tight text-creme mb-4" style="text-shadow: 0 2px 16px rgba(0,0,0,0.6);">
          Feiern Sie bei uns
        </h1>
        <p class="text-base text-creme/90 max-w-2xl mx-auto leading-relaxed" style="text-shadow: 0 1px 8px rgba(0,0,0,0.5);">
          Firmenevents, Geburtstage, Vereinsfeiern — mit Kinoerlebnis, Catering und Kinogarten.
        </p>
      </div>
    </section>

    <section class="bg-off-white px-6 py-16" style="background: #FAF6EE;">
      <div class="max-w-5xl mx-auto">
        <p class="text-xs uppercase tracking-[0.2em] text-warmes-braun mb-3 text-center">Räume im Überblick</p>
        <h2 class="font-display text-3xl text-tiefschwarz text-center mb-8">Was Sie mieten können</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          {sortierteSaele.map((saal) => (
            <a
              href={`/saele#${saal.slug.current}`}
              class="bg-creme border rounded p-3 sm:p-4 text-center min-w-0 hover:shadow-md transition-shadow"
              style={`border-top: 2px solid ${saal.farbakzent ?? "#C9A55C"}; border-color: #E5D8C0; border-top-color: ${saal.farbakzent ?? "#C9A55C"}; background: #F5EDE0;`}
            >
              <div class="font-display text-base sm:text-lg md:text-xl text-tiefschwarz mb-1 leading-tight break-words">{saal.name}</div>
              <div class="text-xs text-warmes-braun uppercase tracking-widest">{saal.plaetze} Plätze</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-creme px-6 py-16" style="background: #F5EDE0;">
      <div class="max-w-5xl mx-auto">
        <p class="text-xs uppercase tracking-[0.2em] text-warmes-braun mb-3 text-center">So läuft's ab</p>
        <h2 class="font-display text-3xl text-tiefschwarz text-center mb-10">Vier Schritte zum Event</h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          {schritte.map((s) => (
            <div class="text-center">
              <div class="w-12 h-12 rounded-full border-2 border-vintage-gold text-kino-rot font-display text-2xl mx-auto mb-3 flex items-center justify-center">
                {s.nummer}
              </div>
              <div class="font-display text-lg text-tiefschwarz mb-1">{s.titel}</div>
              <div class="text-sm text-warmes-braun leading-relaxed">{s.text}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-off-white px-6 py-16" style="background: #FAF6EE;">
      <div class="max-w-2xl mx-auto">
        <p class="text-xs uppercase tracking-[0.2em] text-warmes-braun mb-3 text-center">Ihre Anfrage</p>
        <h2 class="font-display text-3xl text-tiefschwarz text-center mb-8">Erzählen Sie uns von Ihrem Anlass</h2>

        <form id="vermietung-form" class="space-y-4" novalidate>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs uppercase tracking-widest text-warmes-braun mb-1" for="name">Ihr Name</label>
              <input id="name" name="name" type="text" required autocomplete="name" class="w-full bg-creme border border-vintage-gold/40 rounded px-3 py-2 text-sm text-tiefschwarz focus:border-kino-rot" style="background: #F5EDE0;" />
            </div>
            <div>
              <label class="block text-xs uppercase tracking-widest text-warmes-braun mb-1" for="email">E-Mail</label>
              <input id="email" name="email" type="email" required autocomplete="email" class="w-full bg-creme border border-vintage-gold/40 rounded px-3 py-2 text-sm text-tiefschwarz focus:border-kino-rot" style="background: #F5EDE0;" />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs uppercase tracking-widest text-warmes-braun mb-1" for="datum">Wunsch-Datum</label>
              <input id="datum" name="datum" type="date" class="w-full bg-creme border border-vintage-gold/40 rounded px-3 py-2 text-sm text-tiefschwarz focus:border-kino-rot" style="background: #F5EDE0;" />
            </div>
            <div>
              <label class="block text-xs uppercase tracking-widest text-warmes-braun mb-1" for="raum">Wunsch-Raum</label>
              <select id="raum" name="raum" class="w-full bg-creme border border-vintage-gold/40 rounded px-3 py-2 text-sm text-tiefschwarz focus:border-kino-rot" style="background: #F5EDE0;">
                <option value="">Keine Präferenz</option>
                {sortierteSaele.map((saal) => (
                  <option value={saal.name}>{saal.name} ({saal.plaetze} Plätze)</option>
                ))}
              </select>
            </div>
          </div>

          <div>
            <label class="block text-xs uppercase tracking-widest text-warmes-braun mb-1" for="nachricht">Ihre Nachricht</label>
            <textarea id="nachricht" name="nachricht" rows="5" required placeholder="Erzählen Sie uns von Ihrem Anlass, Anzahl Gäste, Catering-Wünsche …" class="w-full bg-creme border border-vintage-gold/40 rounded px-3 py-2 text-sm text-tiefschwarz focus:border-kino-rot" style="background: #F5EDE0;"></textarea>
          </div>

          <div class="text-center pt-2">
            <button
              id="vermietung-submit"
              type="submit"
              class="bg-kino-rot text-creme px-8 py-3 rounded font-medium tracking-wider hover:bg-tiefschwarz transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
            >
              <span data-idle>Anfrage senden</span>
              <span data-loading class="hidden">Wird gesendet …</span>
            </button>
            <p id="vermietung-hint" class="text-xs text-warmes-braun mt-3">
              Alternativ per E-Mail an <a href="mailto:veranstaltung@kinoweinheim.de" class="text-kino-rot">veranstaltung@kinoweinheim.de</a> oder Tel. <a href="tel:0620162155" class="text-kino-rot">06201 · 62155</a>
            </p>
            <p class="text-xs text-warmes-braun/90 italic mt-2 max-w-md mx-auto">
              Ihre Angaben werden ausschließlich zur Bearbeitung Ihrer Anfrage verwendet. Details in unserer <a href="/datenschutz" class="text-kino-rot underline">Datenschutzerklärung</a>.
            </p>
          </div>

        </form>

        <div
          id="vermietung-status"
          role="status"
          aria-live="polite"
          class="mt-6 text-sm hidden"
        ></div>

        <script>
          const form = document.getElementById("vermietung-form") as HTMLFormElement | null
          const btn = document.getElementById("vermietung-submit") as HTMLButtonElement | null
          const idleLabel = btn?.querySelector<HTMLElement>("[data-idle]") ?? null
          const loadingLabel = btn?.querySelector<HTMLElement>("[data-loading]") ?? null
          const status = document.getElementById("vermietung-status")
          const hint = document.getElementById("vermietung-hint")

          function setLoading(loading: boolean) {
            if (!btn || !idleLabel || !loadingLabel) return
            btn.disabled = loading
            idleLabel.classList.toggle("hidden", loading)
            loadingLabel.classList.toggle("hidden", !loading)
          }

          function zeigeStatus(nachricht: string, art: "success" | "error") {
            if (!status) return
            status.classList.remove("hidden")
            status.className = `mt-6 text-sm rounded border px-4 py-3 ${
              art === "success"
                ? "text-tiefschwarz border-vintage-gold/60"
                : "text-tiefschwarz border-kino-rot/50"
            }`
            status.style.background = art === "success" ? "#F5EDE0" : "#FAF0E8"
            status.innerHTML = nachricht
          }

          function fokussiereFeld(id: string) {
            const el = document.getElementById(id) as HTMLElement | null
            el?.focus()
          }

          form?.addEventListener("submit", async (event) => {
            event.preventDefault()
            if (!form) return

            const formData = new FormData(form)
            const name = (formData.get("name") ?? "").toString().trim()
            const email = (formData.get("email") ?? "").toString().trim()
            const nachricht = (formData.get("nachricht") ?? "").toString().trim()

            const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/

            if (!name) {
              zeigeStatus("Bitte geben Sie Ihren Namen an.", "error")
              fokussiereFeld("name")
              return
            }
            if (!email) {
              zeigeStatus("Bitte geben Sie eine E-Mail-Adresse an.", "error")
              fokussiereFeld("email")
              return
            }
            if (!EMAIL_REGEX.test(email)) {
              zeigeStatus("Die E-Mail-Adresse sieht nicht korrekt aus.", "error")
              fokussiereFeld("email")
              return
            }
            if (!nachricht) {
              zeigeStatus("Bitte schreiben Sie uns eine Nachricht.", "error")
              fokussiereFeld("nachricht")
              return
            }

            setLoading(true)
            if (status) status.classList.add("hidden")

            try {
              const res = await fetch("/api/vermietung", {
                method: "POST",
                headers: {"content-type": "application/json"},
                body: JSON.stringify({
                  name,
                  email,
                  datum: (formData.get("datum") ?? "").toString(),
                  raum: (formData.get("raum") ?? "").toString(),
                  nachricht,
                }),
              })
              const data = await res.json().catch(() => ({ok: false, message: "Ungültige Antwort vom Server."}))

              if (res.ok && data.ok) {
                form.classList.add("hidden")
                hint?.classList.add("hidden")
                zeigeStatus(
                  "Vielen Dank für Ihre Anfrage — wir haben sie erhalten und melden uns zeitnah mit einem Angebot.",
                  "success"
                )
                status?.scrollIntoView({block: "center", behavior: "smooth"})
              } else {
                zeigeStatus(
                  (data.message ?? "Etwas ist schiefgelaufen.") +
                    " Alternativ per E-Mail an <a href=\"mailto:veranstaltung@kinoweinheim.de\" class=\"text-kino-rot underline\">veranstaltung@kinoweinheim.de</a>.",
                  "error"
                )
              }
            } catch (e) {
              zeigeStatus(
                "Verbindung zum Server fehlgeschlagen. Bitte später erneut versuchen oder per E-Mail an <a href=\"mailto:veranstaltung@kinoweinheim.de\" class=\"text-kino-rot underline\">veranstaltung@kinoweinheim.de</a>.",
                "error"
              )
            } finally {
              setLoading(false)
            }
          })
        </script>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
