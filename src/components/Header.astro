---
const nav = [
  {label: "Start", href: "/"},
  {label: "Programm", href: "/programm"},
  {label: "Säle", href: "/saele"},
  {label: "Vermietung", href: "/vermietung"},
  {label: "Events", href: "/events"},
  {label: "Historie", href: "/historie"},
  {label: "Kontakt", href: "/kontakt"},
]

const currentPath = Astro.url.pathname
---

<header class="bg-tiefschwalz text-creme border-b border-vintage-gold/50" style="background: #1A1310;">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between gap-4">

    <a href="/" class="flex items-center gap-3 shrink-0">
      <span class="bg-creme text-tiefschwarz px-2 py-1 rounded-sm leading-none">
        <span class="block font-display text-sm">Modernes</span>
        <span class="block font-display text-sm">Theater</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-5 text-xs tracking-wider">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "hover:text-vintage-gold transition-colors",
            currentPath === item.href ? "text-vintage-gold" : "text-creme",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href="tel:0620162155"
      class="hidden md:flex items-center gap-2 text-xs text-vintage-gold hover:text-creme transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      06201 · 62155
    </a>

    <button
      class="md:hidden text-creme p-1"
      aria-label="Menü öffnen"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

  </div>
</header>