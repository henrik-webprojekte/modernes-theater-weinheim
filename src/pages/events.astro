---
import Layout from "../layouts/Layout.astro"
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import {getEvents, type Event} from "../lib/sanity"

const events = await getEvents()

function farbeFuerKategorie(kategorie: string): string {
  const farben: Record<string, string> = {
    "kaffee-tee-kino": "#8A6B2E",
    "enzo-day": "#6B1818",
    "open-air": "#4A7038",
    "schmittini": "#8A5F2A",
    "sondervorstellung": "#5A3F7F",
    "sonstiges": "#6B4E1F",
  }
  return farben[kategorie] ?? "#8A6B2E"
}

function formatDatum(startDatum: string, endDatum?: string): string {
  const opt: Intl.DateTimeFormatOptions = {day: "2-digit", month: "2-digit", year: "numeric"}
  const start = new Date(startDatum).toLocaleDateString("de-DE", opt)
  if (!endDatum) return start
  const ende = new Date(endDatum).toLocaleDateString("de-DE", opt)
  return `${start} – ${ende}`
}
---

<Layout
  title="Events — Modernes Theater Weinheim"
  description="Sonderreihen und Events im Modernen Theater Weinheim: Kaffee-Tee-Kino, Enzo-Day, Sneak Preview, Zauberer Schmittini und Open-Air-Sommer."
>
  <Header />

  <main id="hauptinhalt">

    <section class="bg-tiefschwarz text-creme relative" style="background: #1A1310;">
      <div class="absolute top-0 left-0 right-0 h-[3px]" style="background: repeating-linear-gradient(90deg, #C9A55C 0 6px, transparent 6px 12px); opacity: 0.5;"></div>
      <div class="max-w-4xl mx-auto px-6 py-20 md:py-24 text-center">
        <p class="text-xs uppercase tracking-[0.3em] text-vintage-gold mb-3">
          Neben dem Kinoprogramm
        </p>
        <h1 class="font-display text-4xl md:text-6xl leading-tight text-creme mb-4">
          Sonderreihen & Events
        </h1>
        <p class="text-base text-creme/80 max-w-2xl mx-auto leading-relaxed">
          Sonderreihen, Open-Air-Termine und Gastvorstellungen — für alle, die mehr als Blockbuster suchen.
        </p>
      </div>
    </section>

    <section class="bg-creme px-6 py-16" style="background: #F5EDE0;">
      <div class="max-w-5xl mx-auto">
        {events.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {events.map((event: Event) => (
              <a
                href={`/events/${event.slug.current}`}
                class="group bg-off-white border border-vintage-gold/20 rounded p-5 flex flex-col hover:border-vintage-gold/60 hover:shadow-sm transition-all"
                style={`background: #FAF6EE; border-top: 3px solid ${farbeFuerKategorie(event.kategorie)};`}
              >
                <p class="text-[10px] uppercase tracking-[0.2em] mb-2" style={`color: ${farbeFuerKategorie(event.kategorie)};`}>
                  {event.wiederkehrend ?? formatDatum(event.startDatum, event.endDatum)}
                </p>
                <h2 class="font-display text-xl text-tiefschwarz mb-2 leading-tight group-hover:text-kino-rot transition-colors">{event.titel}</h2>
                {event.kurzbeschreibung && (
                  <p class="text-sm text-tiefschwarz/85 leading-relaxed">{event.kurzbeschreibung}</p>
                )}
                {event.ort && (
                  <p class="text-xs text-warmes-braun italic mt-3">Ort: {event.ort}</p>
                )}
                <span class="mt-4 pt-3 border-t border-vintage-gold/20 text-xs text-kino-rot inline-flex items-center gap-1">
                  Details <span aria-hidden="true">→</span>
                </span>
              </a>
            ))}
          </div>
        ) : (
          <div class="bg-off-white border border-vintage-gold/40 rounded p-10 max-w-2xl mx-auto text-center" style="background: #FAF6EE;">
            <p class="font-display text-xl text-tiefschwarz mb-3">Aktuell keine Events geplant</p>
            <p class="text-sm text-tiefschwarz/85 leading-relaxed">
              Sobald neue Sonderreihen, Open-Air-Termine oder Gastvorstellungen feststehen, erscheinen sie an dieser Stelle.
              Für Vermietungen und Sondervorstellungen für Gruppen bleibt <a href="/kontakt" class="text-kino-rot border-b border-vintage-gold/60 hover:text-tiefschwarz transition-colors">unser Kontakt-Bereich</a> jederzeit offen.
            </p>
          </div>
        )}
      </div>
    </section>

  </main>

  <Footer />
</Layout>
